{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "lc3asm",
      "camelcase": "Lc3asm",
      "title": "LC3 Assembly",
      "scope": "source.lc3asm",
      "file-types": [
        "lc3",
        "asm"
      ],
      "injection-regex": "^lc3asm$",
      "class-name": "TreeSitterLc3asm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Assembly language for Little Computer 3",
    "authors": [
      {
        "name": "MyUsernamee",
        "url": "https://www.github.com/MyUsernamee"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-lc3asm",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}