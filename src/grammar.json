{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lc3asm",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "statement"
              },
              {
                "type": "SYMBOL",
                "name": "comment"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "\\n+"
          }
        ]
      }
    },
    "statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "opcode"
                    },
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "SYMBOL",
                          "name": "_operand"
                        },
                        {
                          "type": "BLANK"
                        }
                      ]
                    },
                    {
                      "type": "REPEAT",
                      "content": {
                        "type": "SEQ",
                        "members": [
                          {
                            "type": "STRING",
                            "value": ","
                          },
                          {
                            "type": "SYMBOL",
                            "name": "_operand"
                          }
                        ]
                      }
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "directive"
                    },
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "SYMBOL",
                          "name": "_literal"
                        },
                        {
                          "type": "BLANK"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "directive": {
      "type": "PATTERN",
      "value": "\\.\\w+",
      "flags": "i"
    },
    "comment": {
      "type": "PATTERN",
      "value": ";[^\\n]*"
    },
    "_operand": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "register"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "number_literal"
        }
      ]
    },
    "_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number_literal"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "number_literal": {
      "type": "PATTERN",
      "value": "[x#]\\d+"
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "STRING",
                    "value": "\\\""
                  },
                  {
                    "type": "PATTERN",
                    "value": "[^\"]"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "STRING",
                    "value": "\\'"
                  },
                  {
                    "type": "PATTERN",
                    "value": "[^']"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "register": {
      "type": "PATTERN",
      "value": "R\\d",
      "flags": "i"
    },
    "opcode": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "ADD",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "AND",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "NOT",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "ST[IR]?",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "LD[(EA)IR]?",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "BR[ZNPznp]?",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "JSRR?",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "TRAP",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "HALT",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "GETS",
          "flags": "i"
        },
        {
          "type": "PATTERN",
          "value": "PUTS",
          "flags": "i"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "\\w+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}